{
  "name": "chat-empresarial",
  "version": "1.0.0",
  "description": "Chatbot de gestión empresarial para WhatsApp con Llama 3.3 en Groq",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "logout": "ts-node-dev --transpile-only src/scripts/logout.ts",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "baileys": "^6.7.23",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "groq-sdk": "^0.9.1",
    "mammoth": "^1.8.0",
    "mongoose": "^8.4.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/qrcode-terminal": "^0.12.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
