# ─────────────────────────────────────────
#  Chat-empresarial — Variables de Entorno
# ─────────────────────────────────────────

# Groq API
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# MongoDB
MONGODB_URI=mongodb://localhost:27017/chat-empresarial
MONGODB_DB_NAME=chat-empresarial

# WhatsApp
WA_SESSION_NAME=chat-empresarial-session
# Prefijo de comando para invocar al bot en grupos (ej: !bot hola)
BOT_PREFIX=!bot
# ID del grupo principal (opcional, para restringir el bot a un grupo)
MAIN_GROUP_ID=

# App
NODE_ENV=development
LOG_LEVEL=info
